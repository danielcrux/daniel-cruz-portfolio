{
  "$description": "Daniel Cruz portfolio — design tokens (W3C Design Tokens format). Mirrors assets/tokens.css. See migration-map.md for the value-by-value provenance and the decisions still open before this replaces the hardcoded values in style.css. Fluid font sizes have no Figma equivalent (Figma has no viewport-relative unit), so each fluid step is exported as a `-min` and `-max` pair plus the raw CSS clamp() expression under $extensions for reference.",

  "color": {
    "$description": "Layer 1 primitives. Two independent neutral ramps (light/dark are hand-tuned, not mirrored) plus brand/status/placeholder colors.",
    "neutral": {
      "light": {
        "50":  { "$type": "color", "$value": "#ffffff", "$description": "was --bg (light)" },
        "100": { "$type": "color", "$value": "#f3f2ee", "$description": "was --card (light)" },
        "200": { "$type": "color", "$value": "#e8e7e2", "$description": "was --line (light)" },
        "500": { "$type": "color", "$value": "#8a8a86", "$description": "was --soft (light)" },
        "700": { "$type": "color", "$value": "#4a4a48", "$description": "was --body (light)" },
        "900": { "$type": "color", "$value": "#0f0f0f", "$description": "was --ink (light)" }
      },
      "dark": {
        "50":  { "$type": "color", "$value": "#f5f4f2", "$description": "was --ink (dark)" },
        "300": { "$type": "color", "$value": "#c7c6c2", "$description": "was --body (dark)" },
        "500": { "$type": "color", "$value": "#8f8f8c", "$description": "was --soft (dark)" },
        "700": { "$type": "color", "$value": "#2b2b2c", "$description": "was --line (dark)" },
        "800": { "$type": "color", "$value": "#1b1b1d", "$description": "was --card (dark)" },
        "900": { "$type": "color", "$value": "#111113", "$description": "was --bg (dark)" }
      }
    },
    "base": {
      "black": { "$type": "color", "$value": "#000000" },
      "white": { "$type": "color", "$value": "#ffffff" }
    },
    "brand": {
      "accent": {
        "light": { "$type": "color", "$value": "#ff4d1f" },
        "dark":  { "$type": "color", "$value": "#ff6a3d" }
      },
      "success":     { "$type": "color", "$value": "#33b25a", "$description": "Collapses #33b25a (status dot) + #43bd68 (compare-tag.solution) into one canonical value. DECIDED (conservative): kept #33b25a, the value already used site-wide, so only the single-use compare-tag.solution shifts — see migration-map.md §1.4." },
      "success-ink": { "$type": "color", "$value": "#04310f" },
      "warning":     { "$type": "color", "$value": "#f5c443", "$description": "New role, formalizing the previously-hardcoded compare-tag.current colors — see migration-map.md §1.5." },
      "warning-ink": { "$type": "color", "$value": "#3d3000" }
    },
    "placeholder": {
      "$description": "Case-cover gradient presets. DECIDED (conservative): the near-duplicate warm pair found in case-template.html was kept as its own preset rather than merged, so the template's example cards stay pixel-exact — see migration-map.md §1.6.",
      "warm-1": { "$type": "color", "$value": "#e4e1d8" },
      "warm-2": { "$type": "color", "$value": "#c9c4b3" },
      "warm-alt-1": { "$type": "color", "$value": "#e3ded1" },
      "warm-alt-2": { "$type": "color", "$value": "#c7c0ac" },
      "cool-1": { "$type": "color", "$value": "#dfe3e0" },
      "cool-2": { "$type": "color", "$value": "#b9c2bb" }
    },
    "semantic": {
      "$description": "Layer 2. Role-based tokens components should actually consume. Swapping `dark` for `light` here is the entire theming mechanism.",
      "light": {
        "bg":             { "$type": "color", "$value": "{color.neutral.light.50}" },
        "surface":        { "$type": "color", "$value": "{color.neutral.light.100}" },
        "border":         { "$type": "color", "$value": "{color.neutral.light.200}" },
        "text":           { "$type": "color", "$value": "{color.neutral.light.900}" },
        "text-secondary": { "$type": "color", "$value": "{color.neutral.light.700}" },
        "text-muted":     { "$type": "color", "$value": "{color.neutral.light.500}" },
        "accent":         { "$type": "color", "$value": "{color.brand.accent.light}" },
        "success":        { "$type": "color", "$value": "{color.brand.success}" },
        "success-ink":    { "$type": "color", "$value": "{color.brand.success-ink}" },
        "warning":        { "$type": "color", "$value": "{color.brand.warning}" },
        "warning-ink":    { "$type": "color", "$value": "{color.brand.warning-ink}" },
        "inverse-bg":     { "$type": "color", "$value": "{color.semantic.light.text}" },
        "inverse-text":   { "$type": "color", "$value": "{color.semantic.light.bg}" },
        "placeholder-1":  { "$type": "color", "$value": "{color.placeholder.warm-1}" },
        "placeholder-2":  { "$type": "color", "$value": "{color.placeholder.warm-2}" },
        "placeholder-1-alt": { "$type": "color", "$value": "{color.placeholder.warm-alt-1}" },
        "placeholder-2-alt": { "$type": "color", "$value": "{color.placeholder.warm-alt-2}" },
        "header-bg":      { "$type": "color", "$value": "#ffffffb3", "$description": "white @ 70% alpha (--a-70). Figma variables can't reference alpha composites, so this is pre-flattened to an 8-digit hex." },
        "shadow":         { "$type": "color", "$value": "#0f0f0f1a", "$description": "#0f0f0f @ 10% alpha (--a-10), pre-flattened." }
      },
      "dark": {
        "bg":             { "$type": "color", "$value": "{color.neutral.dark.900}" },
        "surface":        { "$type": "color", "$value": "{color.neutral.dark.800}" },
        "border":         { "$type": "color", "$value": "{color.neutral.dark.700}" },
        "text":           { "$type": "color", "$value": "{color.neutral.dark.50}" },
        "text-secondary": { "$type": "color", "$value": "{color.neutral.dark.300}" },
        "text-muted":     { "$type": "color", "$value": "{color.neutral.dark.500}" },
        "accent":         { "$type": "color", "$value": "{color.brand.accent.dark}" },
        "success":        { "$type": "color", "$value": "{color.brand.success}" },
        "success-ink":    { "$type": "color", "$value": "{color.brand.success-ink}" },
        "warning":        { "$type": "color", "$value": "{color.brand.warning}" },
        "warning-ink":    { "$type": "color", "$value": "{color.brand.warning-ink}" },
        "inverse-bg":     { "$type": "color", "$value": "{color.semantic.dark.text}" },
        "inverse-text":   { "$type": "color", "$value": "{color.semantic.dark.bg}" },
        "placeholder-1":  { "$type": "color", "$value": "{color.placeholder.warm-1}" },
        "placeholder-2":  { "$type": "color", "$value": "{color.placeholder.warm-2}" },
        "placeholder-1-alt": { "$type": "color", "$value": "{color.placeholder.warm-alt-1}" },
        "placeholder-2-alt": { "$type": "color", "$value": "{color.placeholder.warm-alt-2}" },
        "header-bg":      { "$type": "color", "$value": "#111113b3", "$description": "#111113 @ 70% alpha, pre-flattened." },
        "shadow":         { "$type": "color", "$value": "#00000059", "$description": "#000000 @ 35% alpha, pre-flattened." }
      }
    },
    "alpha": {
      "$description": "Named opacity steps for black/white overlays, exact-value mapping from the audit (no forced rounding). $type number since W3C has no opacity primitive.",
      "08": { "$type": "number", "$value": 0.08 },
      "10": { "$type": "number", "$value": 0.10 },
      "18": { "$type": "number", "$value": 0.18 },
      "20": { "$type": "number", "$value": 0.20 },
      "25": { "$type": "number", "$value": 0.25 },
      "35": { "$type": "number", "$value": 0.35 },
      "40": { "$type": "number", "$value": 0.40 },
      "45": { "$type": "number", "$value": 0.45 },
      "50": { "$type": "number", "$value": 0.50 },
      "70": { "$type": "number", "$value": 0.70 },
      "85": { "$type": "number", "$value": 0.85 }
    }
  },

  "font": {
    "family": {
      "body": { "$type": "fontFamily", "$value": ["General Sans", "Inter", "-apple-system", "BlinkMacSystemFont", "Segoe UI", "sans-serif"] },
      "mono":  { "$type": "fontFamily", "$value": ["SF Mono", "Menlo", "Consolas", "monospace"] }
    },
    "size": {
      "static": {
        "$description": "UI/label sizes. DECIDED (conservative): consolidates 4 near-duplicate micro values (11/11.5/12/12.5px) into one 2xs step — the largest delta is 1px on an 11px label, judged imperceptible — see migration-map.md §2.1.",
        "2xs":  { "$type": "dimension", "$value": "12px" },
        "xs":   { "$type": "dimension", "$value": "13px" },
        "sm":   { "$type": "dimension", "$value": "14px" },
        "md":   { "$type": "dimension", "$value": "15px" },
        "base": { "$type": "dimension", "$value": "16px" },
        "lg":   { "$type": "dimension", "$value": "17px" },
        "xl":   { "$type": "dimension", "$value": "18px" },
        "2xl":  { "$type": "dimension", "$value": "19px" },
        "3xl":  { "$type": "dimension", "$value": "20px" },
        "4xl":  { "$type": "dimension", "$value": "34px" }
      },
      "fluid": {
        "$description": "Display/heading sizes. Replaces 10 ad hoc clamp() formulas with one shared construction (linear interpolation, 400px-1440px viewport) — see migration-map.md §2.2. DECIDED (conservative): 9 steps, not 8 — testimonial-quote and case-quote were kept standalone instead of merged, since their original parameters differed enough that merging would visibly resize both. Figma has no viewport unit, so -min/-max are exported separately for reference; $extensions.css carries the real clamp() used on the web.",
        "2xl": {
          "min": { "$type": "dimension", "$value": "52px" },
          "max": { "$type": "dimension", "$value": "132px" },
          "$extensions": { "css": "clamp(52px, 52px + (100vw - 400px) * 80/1040, 132px)" },
          "$description": "hero title"
        },
        "xl": {
          "min": { "$type": "dimension", "$value": "38px" },
          "max": { "$type": "dimension", "$value": "100px" },
          "$extensions": { "css": "clamp(38px, 38px + (100vw - 400px) * 62/1040, 100px)" },
          "$description": "cta title"
        },
        "lg": {
          "min": { "$type": "dimension", "$value": "34px" },
          "max": { "$type": "dimension", "$value": "64px" },
          "$extensions": { "css": "clamp(34px, 34px + (100vw - 400px) * 30/1040, 64px)" },
          "$description": "case title"
        },
        "md": {
          "min": { "$type": "dimension", "$value": "32px" },
          "max": { "$type": "dimension", "$value": "52px" },
          "$extensions": { "css": "clamp(32px, 32px + (100vw - 400px) * 20/1040, 52px)" },
          "$description": "section head h2"
        },
        "quote-testimonial": {
          "min": { "$type": "dimension", "$value": "24px" },
          "max": { "$type": "dimension", "$value": "42px" },
          "$extensions": { "css": "clamp(24px, 24px + (100vw - 400px) * 18/1040, 42px)" },
          "$description": "home testimonial carousel — kept standalone (not merged with case-quote), endpoints unchanged from the original CSS"
        },
        "quote-case": {
          "min": { "$type": "dimension", "$value": "22px" },
          "max": { "$type": "dimension", "$value": "38px" },
          "$extensions": { "css": "clamp(22px, 22px + (100vw - 400px) * 16/1040, 38px)" },
          "$description": "case-quote blockquote — kept standalone, endpoints unchanged from the original CSS"
        },
        "lead": {
          "min": { "$type": "dimension", "$value": "26px" },
          "max": { "$type": "dimension", "$value": "37px" },
          "$extensions": { "css": "clamp(26px, 26px + (100vw - 400px) * 11/1040, 37px)" },
          "$description": "merged: about-lead + case-feature-head h3 — zero-risk merge, both already shared the same min and vw coefficient"
        },
        "heading": {
          "min": { "$type": "dimension", "$value": "24px" },
          "max": { "$type": "dimension", "$value": "36px" },
          "$extensions": { "css": "clamp(24px, 24px + (100vw - 400px) * 12/1040, 36px)" },
          "$description": "service-name"
        },
        "link": {
          "min": { "$type": "dimension", "$value": "22px" },
          "max": { "$type": "dimension", "$value": "36px" },
          "$extensions": { "css": "clamp(22px, 22px + (100vw - 400px) * 14/1040, 36px)" },
          "$description": "cta-email"
        }
      }
    },
    "weight": {
      "regular":  { "$type": "fontWeight", "$value": 400 },
      "medium":   { "$type": "fontWeight", "$value": 500 },
      "semibold": { "$type": "fontWeight", "$value": 600 },
      "bold":     { "$type": "fontWeight", "$value": 700 }
    },
    "lineHeight": {
      "$description": "DECIDED (conservative), see migration-map.md §2.3: only merges values that were already explicit and near-identical in the CSS. Selectors with no explicit line-height today (section-head h2, service-name, case-feature-head h3, cta-email) are NOT given a new one here — they keep inheriting `body` (1.55) exactly as today, since tightening to 1.1/1.35 would be clearly visible, not a rounding.",
      "tight":   { "$type": "number", "$value": 1 },
      "snug":    { "$type": "number", "$value": 1.08 },
      "relaxed": { "$type": "number", "$value": 1.35 },
      "loose":   { "$type": "number", "$value": 1.6 },
      "body":    { "$type": "number", "$value": 1.55 }
    },
    "letterSpacing": {
      "tightest": { "$type": "dimension", "$value": "-0.04em" },
      "tighter":  { "$type": "dimension", "$value": "-0.03em" },
      "tight":    { "$type": "dimension", "$value": "-0.02em" },
      "snug":     { "$type": "dimension", "$value": "-0.01em" },
      "normal":   { "$type": "dimension", "$value": "0em" },
      "wide":     { "$type": "dimension", "$value": "0.06em", "$description": "also absorbs the single .04em outlier from .scroll-hint — see migration-map.md §2.4" },
      "wider":    { "$type": "dimension", "$value": "0.08em" }
    }
  },

  "space": {
    "$description": "4px-base micro scale for gap/margin/padding.",
    "1":  { "$type": "dimension", "$value": "4px" },
    "2":  { "$type": "dimension", "$value": "8px" },
    "3":  { "$type": "dimension", "$value": "12px" },
    "4":  { "$type": "dimension", "$value": "16px" },
    "5":  { "$type": "dimension", "$value": "20px" },
    "6":  { "$type": "dimension", "$value": "24px" },
    "7":  { "$type": "dimension", "$value": "32px" },
    "8":  { "$type": "dimension", "$value": "40px" },
    "9":  { "$type": "dimension", "$value": "56px" },
    "10": { "$type": "dimension", "$value": "80px" }
  },

  "layout": {
    "$description": "Macro section-padding values. DECIDED (conservative), see migration-map.md §3.2: NOT consolidated into 3 tiers as first proposed — a ±10px shift on section padding is a deliberate design change, not a rounding, so every distinct desktop value keeps its own token. `section-mobile` is not a rounding either, it's the exact value the responsive breakpoint already uses today for 4 of these 5 selectors (case-feature is the one exception, unchanged at every viewport).",
    "section-90":  { "$type": "dimension", "$value": "90px", "$description": "case sub-hero padding-top, today inline in 4 case-*.html files" },
    "section-100": { "$type": "dimension", "$value": "100px", "$description": ".case-feature (no responsive override today)" },
    "section-120": { "$type": "dimension", "$value": "120px", "$description": ".case-body" },
    "section-130": { "$type": "dimension", "$value": "130px", "$description": ".case-quote" },
    "section-140": { "$type": "dimension", "$value": "140px", "$description": ".more-work" },
    "section-150": { "$type": "dimension", "$value": "150px", "$description": "section, .case-hero" },
    "section-mobile": { "$type": "dimension", "$value": "96px", "$description": "@max-width:960px override shared by section, .case-body, .more-work, .case-quote today" }
  },

  "radius": {
    "lg": { "$type": "dimension", "$value": "28px" },
    "md": { "$type": "dimension", "$value": "18px" },
    "sm": { "$type": "dimension", "$value": "999px" }
  },

  "shadow": {
    "elevated": {
      "$type": "shadow",
      "$value": {
        "color": "{color.semantic.light.shadow}",
        "offsetX": "0px",
        "offsetY": "18px",
        "blur": "40px",
        "spread": "0px"
      },
      "$description": "The site's one real elevation shadow (.float-cta). Color swaps to color.semantic.dark.shadow in dark mode."
    }
  },

  "duration": {
    "$description": "7 raw durations collapsed to the 3 mandated for this scale. DECIDED (conservative), see migration-map.md §6: 500ms kept for `slow` because it was already the majority value in that tier (~4 uses vs ~2 each of .4s/.6s) — the option that minimizes total drift given the fixed 3-duration constraint. .4s (+100ms) and .6s (-100ms) are the only two values in the whole motion system whose merge is clearly noticeable rather than imperceptible.",
    "fast": { "$type": "duration", "$value": "200ms" },
    "base": { "$type": "duration", "$value": "300ms" },
    "slow":  { "$type": "duration", "$value": "500ms" }
  },

  "easing": {
    "brand": { "$type": "cubicBezier", "$value": [0.16, 1, 0.3, 1] }
  }
}
